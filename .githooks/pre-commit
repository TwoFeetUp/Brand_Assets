#!/usr/bin/env node

/**
 * TwoFeetUp Brand Assets — pre-commit hook
 *
 * Blokkeert commits die niet voldoen aan de naamgevings- en manifest-regels.
 * Zie CLAUDE.md voor de volledige regels.
 */

const { execSync } = require("child_process");
const path = require("path");

// ─── Staged bestanden ophalen ──────────────────────────────────────────────────

function getStagedFiles() {
  const output = execSync("git diff --cached --name-status", { encoding: "utf8" });
  return output
    .trim()
    .split("\n")
    .filter(Boolean)
    .map((line) => {
      const parts = line.split("\t");
      return { status: parts[0], file: parts[parts.length - 1] };
    });
}

const staged = getStagedFiles();
const errors = [];

const newFiles = staged.filter((f) => f.status === "A");
const manifestUpdated = staged.some((f) => f.file === "manifest.json");

const MEDIA_EXTS = [".jpg", ".jpeg", ".png", ".webp", ".gif", ".svg", ".mp4", ".mov", ".avi", ".mkv", ".m4v"];

const newMediaFiles = newFiles.filter((f) =>
  MEDIA_EXTS.includes(path.extname(f.file).toLowerCase())
);

// ─── Regel 1: manifest.json moet bijgewerkt zijn bij nieuwe mediabestanden ─────

if (newMediaFiles.length > 0 && !manifestUpdated) {
  errors.push({
    rule: "MANIFEST_NOT_UPDATED",
    message: `${newMediaFiles.length} nieuw(e) mediabestand(en) toegevoegd, maar manifest.json is niet bijgewerkt.`,
    files: newMediaFiles.map((f) => `  - ${f.file}`),
    fix: "Voeg voor elk nieuw bestand een entry toe aan manifest.json (path, name, description, uploadedAt).",
  });
}

// ─── Regel 2: edited/ bestanden moeten beschrijvende snake_case namen hebben ──

const CAMERA_PATTERN = /^(img|dsc|dscn|p|pic|photo|video|mov|vlc|whatsapp|screenshot)[-_]/i;
const TIMESTAMP_ONLY = /^\d{8}[-_]\d{6}/;
const SNAKE_CASE_MIN2 = /^[a-z][a-z0-9]*(_[a-z0-9]+)+$/;

newFiles
  .filter((f) => f.file.startsWith("edited/"))
  .forEach((f) => {
    const basename = path.basename(f.file, path.extname(f.file));
    const ext = path.extname(f.file).toLowerCase();

    if (ext !== ".webp") {
      errors.push({
        rule: "EDITED_MUST_BE_WEBP",
        message: `Bestand in edited/ moet .webp zijn: ${f.file}`,
        fix: "Converteer naar WebP vóór upload naar edited/.",
      });
    }

    if (CAMERA_PATTERN.test(basename) || TIMESTAMP_ONLY.test(basename)) {
      errors.push({
        rule: "EDITED_CAMERA_NAME",
        message: `Cameranaam niet toegestaan in edited/: ${f.file}`,
        fix: `Hernoem naar beschrijvende naam, bijv: workshop_team_demo.webp`,
      });
    } else if (!SNAKE_CASE_MIN2.test(basename)) {
      errors.push({
        rule: "EDITED_NAME_FORMAT",
        message: `Naam voldoet niet aan snake_case (minimaal 2 woorden): ${f.file}`,
        fix: `Gebruik: woord_woord_woord.webp — bijv: hackathon_keynote_spreker.webp`,
      });
    }
  });

// ─── Regel 3: images/external/ moet naamconventie volgen ──────────────────────

newFiles
  .filter((f) => f.file.startsWith("images/external/"))
  .forEach((f) => {
    const basename = path.basename(f.file);
    if (!/^external_[A-Za-z]+_[A-Za-z]/.test(basename)) {
      errors.push({
        rule: "EXTERNAL_NAME_FORMAT",
        message: `Bestand in images/external/ volgt naamconventie niet: ${f.file}`,
        fix: `Gebruik: external_[Naam]_[Organisatie].[ext] — bijv: external_Anna_Bakker_Accenture.jpg`,
      });
    }
  });

// ─── Regel 4: raw/ bestanden mogen geen puur UUID-formaat hebben ──────────────

const UUID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/i;

newFiles
  .filter((f) => f.file.startsWith("raw/"))
  .forEach((f) => {
    const basename = path.basename(f.file, path.extname(f.file));
    if (UUID_PATTERN.test(basename)) {
      errors.push({
        rule: "RAW_UUID_NAME",
        message: `UUID-bestandsnaam niet toegestaan: ${f.file}`,
        fix: `Hernoem naar iets leesbaars, zelfs in raw/ — bijv: zomerkamp_groepsfoto.jpg`,
      });
    }
  });

// ─── Output ────────────────────────────────────────────────────────────────────

if (errors.length > 0) {
  console.error("\n❌  Commit geblokkeerd — Brand Assets regels overtreden\n");
  console.error("─".repeat(60));

  errors.forEach((err, i) => {
    console.error(`\n${i + 1}. [${err.rule}]`);
    console.error(`   ${err.message}`);
    if (err.files) {
      err.files.forEach((f) => console.error(`   ${f}`));
    }
    console.error(`   ✏️  Fix: ${err.fix}`);
  });

  console.error("\n" + "─".repeat(60));
  console.error("📖  Alle regels: zie CLAUDE.md in de root van deze repo");
  console.error("    https://github.com/TwoFeetUp/Brand_Assets/blob/main/CLAUDE.md\n");
  process.exit(1);
}

process.exit(0);
